# RoyaltyFlux Backend Environment Variables
# Copy this file to .env and fill in real values

PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/royaltyflux

# JWT — use a 64+ character random string (never commit real value)
JWT_SECRET=change_this_to_a_64_character_random_string_before_deploy

# Blockchain
AVALANCHE_RPC=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113
CONTRACT_ADDRESS=0xCHANGE_ME_AFTER_CONTRACT_DEPLOYMENT
# Deployer wallet private key (test only — use dedicated env in production)
PRIVATE_KEY=your_deployer_wallet_private_key_here

# IPFS
IPFS_GATEWAY=https://ipfs.infura.io/ipfs/
IPFS_PROJECT_ID=
IPFS_PROJECT_SECRET=

# Oracle (set after Chainlink oracle is deployed)
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# Redis (optional — for background jobs / caching)
REDIS_URL=redis://localhost:6379

# M-Pesa / Safaricom Daraja
# Get sandbox keys from https://developer.safaricom.co.ke/
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_PASSKEY=your_sandbox_passkey
MPESA_SHORTCODE=174379
# Must be a publicly reachable HTTPS URL (use ngrok in development)
MPESA_CALLBACK_URL=https://<your-ngrok-subdomain>.ngrok-free.app/api/v1/mpesa/callback

# Monitoring (optional)
SENTRY_DSN=
